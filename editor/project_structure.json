  "risks": [
    {
      "title": "Шрифты на Canvas",
      "description": "Шрифты могут не загрузиться до рендера",
      "solution": "FontFaceObserver + ожидание загрузки, fallback на системные шрифты"
    },
    {
      "title": "Большие изображения",
      "description": "Изображения >10 МБ вызывают зависание",
      "solution": "Валидация + сжатие через createImageBitmap или canvas resize"
    },
    {
      "title": "localStorage лимит",
      "description": "Переполнение при большом числе шаблонов",
      "solution": "Не хранить base64 превью, генерировать динамически"
    },
    {
      "title": "Производительность canvas",
      "description": "Холсты >2000×2000 px тормозят",
      "solution": "Ограничение макс. размера 1920×1080, виртуализация при >50 контейнерах"
    }
  ]
}
