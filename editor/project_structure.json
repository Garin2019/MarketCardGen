  "typeScriptInterfaces": {
    "ShapeType": "type ShapeType = 'rect' | 'oval' | 'circle'",
    "FontSettings": {
      "family": "string",
      "size": "number",
      "color": "string",
      "bold": "boolean",
      "italic": "boolean"
    },
    "Container": {
      "id": "string",
      "shape": "ShapeType",
      "x": "number",
      "y": "number",
      "width": "number",
      "height": "number",
      "zIndex": "number",
      "bgColor": "string",
      "bgOpacity": "number",
      "paddingX": "number",
      "paddingY": "number",
      "font": "FontSettings",
      "placeholder": "string"
    },
    "Template": {
      "id": "string",
      "name": "string",
      "width": "number",
      "height": "number",
      "createdAt": "string",
      "containers": "Container[]"
    },
    "CardState": {
      "image": "string | null",
      "selectedTemplateId": "string | null",
      "containerTexts": "Record<string, string>"
    }
  },
