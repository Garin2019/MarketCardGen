# =============================================================
# Marketplace Card App — пример конфигурации
# Скопируйте файл: cp .env.example .env
# Заполните значения перед запуском
# =============================================================

# ----- Приложение -----
DATABASE_PATH=./data/app.db
UPLOAD_DIR=./data/uploads
# CORS — через запятую. Для продакшна добавьте свой домен:
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Логирование -----
LOG_DIR=./data/logs       # папка для файлов логов
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# URL встроенного редактора карточек / инфографики
EDITOR_URL=http://localhost:3000/editor/
# Внешний публичный URL backend, через который AI-провайдеры могут забрать uploaded reference image
# Нужен для MiniMax image generation с subject_reference; localhost для облачного API не подойдёт
PUBLIC_BASE_URL=

# ----- ИИ — Генерация текста -----

# OpenRouter — бесплатный доступ к множеству LLM
# Получить ключ: https://openrouter.ai/ → Sign In → Keys
# Список бесплатных моделей: https://openrouter.ai/models?max_price=0
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free   # можно заменить на любую :free модель

# Qwen / DashScope — текст и image-to-image
# Получить ключ: https://www.alibabacloud.com/help/en/model-studio/
DASHSCOPE_API_KEY=
QWEN_TEXT_MODEL=qwen3.5-plus
QWEN_IMAGE_MODEL=qwen-image-edit

# OpenAI — текст и изображения
# Документация: https://developers.openai.com/
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

# MiniMax — текст и изображения
# Документация: https://platform.minimax.io/docs/
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.5
MINIMAX_IMAGE_MODEL=image-01

# ----- Соцсети -----

# VK — публикация от имени сообщества
# Токен: Управление сообществом → Работа с API → Создать ключ
# owner_id: ID сообщества с минусом (например -123456789)
VK_ACCESS_TOKEN=
VK_OWNER_ID=

# Telegram — публикация в канал через бота
# Создать бота: @BotFather → /newbot
# channel_id: @название канала (канал должен быть публичный)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# MAX — публикация в канал
MAX_ACCESS_TOKEN=
MAX_CHANNEL_ID=
